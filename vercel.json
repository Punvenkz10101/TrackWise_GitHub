{
    "version": 2,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ],
    "ignoreCommand": "git diff --quiet HEAD^ HEAD .",
    "env": {
        "VITE_API_URL": "https://track-wise-server.vercel.app"
    }
}
